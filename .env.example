# .env.example
# Copy this file to .env and fill in your values.
# Vite exposes variables prefixed with VITE_ to the browser bundle.

# Base URL of your OpenAI-compatible LLM server (e.g. LM Studio)
VITE_LLM_BASE_URL=http://localhost:1234/v1

# API key — many local servers accept any non-empty string
VITE_LLM_API_KEY=lm-studio

# Model identifier as reported by your server (e.g. a Llama or Mistral model slug)
VITE_LLM_MODEL=local-model
